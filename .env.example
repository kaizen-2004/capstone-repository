# Backend network binding
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8765

# Note: runtime-capable values can be overridden from Dashboard Settings.
# .env remains the startup default source/fallback.

# Admin account
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Remote access endpoint resolution
LAN_BASE_URL=http://192.168.1.8:8765
TAILSCALE_BASE_URL=http://100.123.42.91:8765
MDNS_ENABLED=true
MDNS_SERVICE_NAME=thesis-monitor
MDNS_HOSTNAME=steve

# Telegram delivery (required for link + fallback messages)
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me
TELEGRAM_LINK_NOTIFICATIONS_ENABLED=true

# Optional push notifications (web push)
WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=
WEBPUSH_VAPID_SUBJECT=mailto:admin@localhost

# Cameras
# Camera source mode: rtsp (default production) or webcam (temporary local test)
CAMERA_SOURCE_MODE=rtsp
# Webcam test node mode: cam_door (single-cam outdoor), cam_indoor, or none (dual webcam workers)
CAMERA_WEBCAM_SINGLE_NODE=cam_door
CAMERA_INDOOR_RTSP=
CAMERA_DOOR_RTSP=
CAMERA_INDOOR_WEBCAM_INDEX=0
CAMERA_DOOR_WEBCAM_INDEX=1
CAMERA_PROCESSING_FPS=12
# Face recognition runtime (YuNet detector + SFace recognizer)
FACE_COSINE_THRESHOLD=0.52
FACE_DETECTOR_MODEL_PATH=backend/storage/models/face/face_detection_yunet_2023mar.onnx
FACE_RECOGNIZER_MODEL_PATH=backend/storage/models/face/face_recognition_sface_2021dec.onnx
FACE_DETECT_SCORE_THRESHOLD=0.90
FACE_DETECT_NMS_THRESHOLD=0.30
FACE_DETECT_TOP_K=5000
# Fire model runtime (FireNet converted artifact, OpenCV DNN on CPU)
FIRE_MODEL_ENABLED=true
FIRE_MODEL_PATH=backend/storage/models/fire/firenet.pb
FIRE_MODEL_THRESHOLD=0.5
FIRE_MODEL_INPUT_SIZE=224
# For 2-class output vectors, set index used as "fire" probability
FIRE_MODEL_FIRE_CLASS_INDEX=0
# Optional test mode: auto-log AUTHORIZED events when an enrolled face re-enters camera view
AUTHORIZED_PRESENCE_LOGGING_ENABLED=false
# Shared scan interval (seconds) for authorized + unknown presence scans
AUTHORIZED_PRESENCE_SCAN_SECONDS=2
AUTHORIZED_PRESENCE_COOLDOWN_SECONDS=20
# Optional test mode: auto-log UNKNOWN events/alerts when unknown face re-enters camera view
UNKNOWN_PRESENCE_LOGGING_ENABLED=false
UNKNOWN_PRESENCE_COOLDOWN_SECONDS=20
# Sensor-trigger cooldown (seconds) to suppress repeated intruder events from same node
INTRUDER_EVENT_COOLDOWN_SECONDS=20

# Runtime and retention
NODE_OFFLINE_SECONDS=120
CAMERA_OFFLINE_SECONDS=45
EVENT_RETENTION_DAYS=90
REGULAR_SNAPSHOT_RETENTION_DAYS=30
CRITICAL_SNAPSHOT_RETENTION_DAYS=90
LOG_RETENTION_DAYS=30
